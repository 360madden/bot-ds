{
  "AllowedHosts": "localhost",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "BotDs": {
    "Dashboard": {
      "ApiToken": "",
      "ControlToken": ""
    },
    "Evaluator": {
      "MaximumTelemetryAgeMs": 5000,
      "EvaluationIntervalMs": 100
    },
    "Profiles": {
      "Directory": "../../profiles"
    }
  }
}
