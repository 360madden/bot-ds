{
  "AllowedHosts": "localhost",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "BotDs": {
    "Scanner": {
      "ProcessName": "rift_x64",
      "ProcessId": null,
      "ReadIntervalMs": 50,
      "LocalMaxAgeMs": 500
    },
    "Evaluator": {
      "MaximumTelemetryAgeMs": 500,
      "EvaluationIntervalMs": 100
    },
    "Action": {
      "AcknowledgementTimeoutMs": 2000,
      "MaxGlobalPerSecond": 4,
      "MaxPerKeyPerSecond": 2,
      "RequireBindingVerificationForLive": true,
      "RequireEmergencyHotkeyForLive": true,
      "DetectExternalActionConflicts": true,
      "EmergencyHotkey": "Ctrl+Shift+F12",
      "UseWindowsEmergencyHotkey": true
    },
    "Profiles": {
      "Directory": "../../profiles"
    }
  }
}
